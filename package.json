{
  "name": "keshavai",
  "displayName": "KeshavAi",
  "publisher": "KeshavSoft",
  "description": "KeshavSoft AI with voice capture",
  "version": "1.1.6",
  "type": "module",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keshavsoft/keshavai.git"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keshavai.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "keshavai.rightClickRoot",
        "title": "rightClickRoot"
      },
      {
        "command": "keshavai.rightClickFolder",
        "title": "rightClickFolder"
      },
      {
        "command": "keshavai.rightClickFile",
        "title": "rightClickFile"
      },
      {
        "command": "voice",
        "title": "voice"
      },
      {
        "command": "keshavai.showHtml",
        "title": "showHtml"
      },
      {
        "command": "keshavai.FetchAsPost",
        "title": "fetchAsPost"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "keshavai.rightClickRoot",
          "group": "navigation",
          "when": "explorerResourceIsRoot"
        },
        {
          "command": "keshavai.rightClickFolder",
          "group": "navigation",
          "when": "explorerResourceIsFolder && !explorerResourceIsRoot"
        },
        {
          "command": "keshavai.FetchAsPost",
          "group": "navigation",
          "when": "explorerResourceIsFolder && !explorerResourceIsRoot"
        }
      ],
      "editor/context": [
        {
          "command": "keshavai.rightClickFile",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}